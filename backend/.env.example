# Monitor IA — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores

# Servidor
PORT=3001
NODE_ENV=development

# Google Gemini API Key (necessária para geração de conteúdo com IA)
# Obtenha em: https://aistudio.google.com/
GEMINI_API_KEY=

# Serper API Key (busca web) — opcional
# Obtenha em: https://serper.dev
SERPER_API_KEY=

# Data do concurso (formato YYYY-MM-DD)
EXAM_DATE=2026-10-19

# Caminho do banco de dados SQLite
DB_PATH=./data/monitor-ia.db

# Pasta de uploads
UPLOADS_PATH=./uploads
